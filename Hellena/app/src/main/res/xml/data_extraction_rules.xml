<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude voice messages from cloud backup for privacy -->
        <exclude domain="file" path="voice_messages/"/>
        
        <!-- Include app preferences -->
        <include domain="sharedpref" path="hellena_prefs.xml"/>
    </cloud-backup>
    
    <device-transfer>
        <!-- Exclude voice messages from device transfer for privacy -->
        <exclude domain="file" path="voice_messages/"/>
        
        <!-- Include app preferences -->
        <include domain="sharedpref" path="hellena_prefs.xml"/>
    </device-transfer>
</data-extraction-rules>